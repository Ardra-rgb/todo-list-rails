<div class="edit-task-page">

  <div class="edit-task-card">

    <h1>Edit Task</h1>

    <p class="edit-subtitle">
      Update your task or add more details to the description.
    </p>

    <%= form_with model: @task,
                  url: "/tasks/#{@task.id}",
                  method: :patch,
                  class: "edit-task-form" do |f| %>

      <div class="form-group">
        <%= f.label :title, "Task" %>
        <%= f.text_field :title,
                         placeholder: "Enter your task",
                         class: "edit-input" %>
      </div>

      <div class="form-group">
        <%= f.label :description, "Description" %>
        <%= f.text_area :description,
                        placeholder: "Add or update your task description",
                        class: "edit-description" %>
      </div>

      <div class="edit-actions">

        <%= f.submit "Save Changes", class: "save-changes-btn" %>

        <%= link_to "Cancel",
                    "/dashboard/index",
                    class: "cancel-btn" %>

      </div>

    <% end %>

  </div>

</div>