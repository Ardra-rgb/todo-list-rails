<div class="new-task-page">

  <h1>Add New Task</h1>

  <%= form_with model: @task,
                url: "/tasks/create",
                method: :post,
                class: "new-task-form" do |f| %>

    <p>
      <%= f.label :title, "Task" %><br>
      <%= f.text_field :title, placeholder: "Enter your task" %>
    </p>

    <p>
      <%= f.label :description, "Description" %><br>
      <%= f.text_area :description, placeholder: "Enter task description" %>
    </p>

    <%= f.submit "Save Task" %>

  <% end %>

</div>